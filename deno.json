{
  "imports": {
    "vue": "npm:vue@^3.4",
    "vue-router": "npm:vue-router@^4.2",
    "~/App.vue": "./src/App.vue",
    "~/": "./src/",
    "~/constants": "./src/constants.ts",
    "~/audio": "./src/audio/index.ts",
    "~/stores": "./src/stores/index.ts",
    "~/stores/app": "./src/stores/app/index.ts",
    "~/stores/patch": "./src/stores/patch/index.ts",
    "~/styles/": "./src/styles/",
    "~/utils/logger": "./src/utils/logger.ts",
    "~/utils/register": "./src/utils/register.ts",
    "~/utils/validatePatch": "./src/utils/validatePatch.ts",
    "~/types/generated": "./src/types/generated.ts"
  },
  "tasks": {
    "build": "pnpm vite build",
    "deploy": "deno task build && deployctl deploy --project=de45f9f1-c75e-43ba-9957-4d84053c52dd --static=./dist"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"]
  }
}
